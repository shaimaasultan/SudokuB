{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "web-dist",
    "rootDir": "web",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["web/**/*", "src/**/*"]
}
